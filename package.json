{
  "name": "@megaeth/wallet-cli",
  "version": "0.1.0",
  "description": "MegaETH wallet CLI for delegated-key local workflows.",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "bin": {
    "mega": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"const fs=require('fs'); fs.chmodSync('dist/index.js', 0o755)\"",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "commander": "^14.0.2",
    "porto": "0.2.37",
    "viem": "2.48.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.23.0"
}
