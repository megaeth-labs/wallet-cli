{
  "name": "@megaeth/wallet-cli",
  "version": "0.1.0",
  "description": "MegaETH wallet CLI for delegated-key local workflows.",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "bin": {
    "mega": "./dist/index.js",
    "wallet": "./dist/wallet.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"const fs=require('fs'); for (const file of ['dist/index.js', 'dist/wallet.js']) fs.chmodSync(file, 0o755)\"",
    "e2e:functional": "npm run build && node scripts/wallet-functional-e2e.mjs",
    "e2e:functional:writes": "npm run e2e:functional -- --writes",
    "e2e:loopback": "npm run build && node scripts/loopback-e2e.mjs",
    "e2e:loopback:screen": "npm run e2e:loopback -- --screen-only",
    "install:local": "scripts/install.sh",
    "install:skill": "scripts/install-skill.sh",
    "uninstall:local": "scripts/uninstall.sh",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "commander": "^14.0.2",
    "porto": "0.2.37",
    "viem": "2.48.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "playwright": "1.59.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.23.0"
}
