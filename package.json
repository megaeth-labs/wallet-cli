{
  "name": "@megaeth/wallet-cli",
  "version": "0.1.3",
  "description": "MegaETH wallet CLI for delegated-key local workflows.",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "bin": {
    "mega": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json && node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "e2e:functional": "npm run build && node scripts/wallet-functional-e2e.mjs",
    "e2e:functional:writes": "npm run e2e:functional -- --writes",
    "e2e:loopback": "npm run build && node scripts/loopback-e2e.mjs",
    "e2e:device:relay-smoke": "npm run e2e:loopback -- --relay-smoke --auth-flow device",
    "e2e:loopback:relay-smoke": "npm run e2e:loopback -- --relay-smoke",
    "e2e:loopback:screen": "npm run e2e:loopback -- --screen-only",
    "install:local": "scripts/install.sh",
    "install:release": "scripts/install-release.sh",
    "install:skill": "scripts/install-skill.sh",
    "package:release": "scripts/package-release.sh",
    "uninstall:local": "scripts/uninstall.sh",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@megaeth-labs/wallet-intent": "0.1.5",
    "commander": "^14.0.2",
    "porto": "0.2.37",
    "viem": "2.48.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "playwright": "1.59.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.23.0"
}
